CLIP_IDENTIFIER_RETRY_BASE_DELAY_MS=1000
CLIP_IDENTIFIER_RETRY_MAX_DELAY_MS=10000
GEMINI_API_KEY=
GITHUB_TOKEN=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
WHISPER_MODEL=base
MAX_PARALLEL_CLIPS=3
SILENCE_THRESHOLD_DB=-35
SILENCE_MIN_DURATION=0.8
OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
CLIP_MIN_DURATION_SEC=20
CLIP_MAX_DURATION_SEC=30
PREFER_YOUTUBE_TRANSCRIPTS=true
CAPTION_ANIMATE=true

YOUTUBE_CLIENT_ID=
